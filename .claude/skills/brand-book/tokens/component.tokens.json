    "axis": {
      "lineColor":    { "$value": "{color.neutral.300}", "$type": "color" },
      "lineWidth":    { "$value": "{borderWidth.thin}", "$type": "dimension" },
      "tickColor":    { "$value": "{color.neutral.300}", "$type": "color" },
      "tickLength":   { "$value": "6px", "$type": "dimension" },
      "labelColor":   { "$value": "{color.text.secondary}", "$type": "color" },
      "labelSize":    { "$value": "{font.size.xs}", "$type": "dimension" },
      "labelFont":    { "$value": "{font.family.mono}", "$type": "fontFamily" },
      "titleColor":   { "$value": "{color.text.primary}", "$type": "color" },
      "titleSize":    { "$value": "{font.size.sm}", "$type": "dimension" },
      "titleWeight":  { "$value": "{font.weight.medium}", "$type": "fontWeight" }
    },
    "grid": {
      "lineColor":    { "$value": "{color.neutral.100}", "$type": "color" },
      "lineWidth":    { "$value": "{borderWidth.thin}", "$type": "dimension" },
      "lineStyle":    { "$value": "solid", "$type": "string" }
    },
    "tooltip": {
      "background":   { "$value": "{color.neutral.900}", "$type": "color" },
      "text":         { "$value": "{color.white}", "$type": "color" },
      "fontSize":     { "$value": "{font.size.xs}", "$type": "dimension" },
      "borderRadius": { "$value": "{radius.md}", "$type": "dimension" },
      "padding":      { "$value": "{space.2}", "$type": "dimension" },
      "shadow":       { "$value": "{shadow.md}", "$type": "shadow" }
    },
    "legend": {
      "fontSize":     { "$value": "{font.size.xs}", "$type": "dimension" },
      "fontWeight":   { "$value": "{font.weight.regular}", "$type": "fontWeight" },
      "color":        { "$value": "{color.text.secondary}", "$type": "color" },
      "swatchSize":   { "$value": "12px", "$type": "dimension" },
      "swatchRadius": { "$value": "{radius.sm}", "$type": "dimension" },
      "gap":          { "$value": "{space.4}", "$type": "dimension" },
      "position":     { "$value": "bottom", "$type": "string", "$extensions": { "variants": ["bottom", "right", "top"], "guidance": "bottom = default for most charts. right = when legend items > 6 or chart is wide. top = when chart is below a title and legend needs to be first." } }
    }
  },

  "divider": {
    "$description": "Content divider/separator. 3 variants.",

    "default": {
      "color":     { "$value": "{color.neutral.200}", "$type": "color" },
      "width":     { "$value": "{borderWidth.thin}", "$type": "dimension" },
      "style":     { "$value": "solid", "$type": "string" },
      "marginY":   { "$value": "{spacing.content.lg}", "$type": "dimension" }
    },
    "thick": {
      "$description": "Heavy divider for major section breaks.",
      "color":     { "$value": "{color.brand.secondary}", "$type": "color" },
      "width":     { "$value": "{borderWidth.thick}", "$type": "dimension" },
      "style":     { "$value": "solid", "$type": "string" },
      "marginY":   { "$value": "{spacing.content.xl}", "$type": "dimension" }
    },
    "accent": {
      "$description": "Branded accent divider for visual emphasis.",
      "color":     { "$value": "{color.brand.accent}", "$type": "color" },
      "width":     { "$value": "{borderWidth.medium}", "$type": "dimension" },
      "style":     { "$value": "solid", "$type": "string" },
      "marginY":   { "$value": "{spacing.content.lg}", "$type": "dimension" }
    }
  },

  "badge-audience": {
    "$description": "Audience-specific badge variant. References audience accent tokens from semantic layer.",
    "background":   { "$value": "{color.audience.{segment}.accent}", "$type": "color", "$description": "Replace {segment} with audience ID from brand-config (e.g., grower, neocloud)." },
    "text":         { "$value": "{color.white}", "$type": "color" },
    "borderRadius": { "$value": "{radius.full}", "$type": "dimension" },
    "paddingX":     { "$value": "{space.3}", "$type": "dimension" },
    "paddingY":     { "$value": "{space.1}", "$type": "dimension" },
    "fontSize":     { "$value": "{font.size.xs}", "$type": "dimension" },
    "fontWeight":   { "$value": "{font.weight.medium}", "$type": "fontWeight" },
    "$extensions": {
      "usage": "Use to visually tag content targeted at a specific audience segment. Resolve {segment} at build time from audience_segments in brand-config.",
      "a11y": "Ensure white text passes 4.5:1 contrast on each audience accent color. All DE defaults pass."
    }
  },

  "callout-audience": {
    "$description": "Audience-specific callout variant. Left accent border uses audience color.",
    "background":   { "$value": "{color.surface.subtle}", "$type": "color" },
    "border":       { "$value": "{color.audience.{segment}.accent}", "$type": "color", "$description": "Replace {segment} with audience ID." },
    "borderWidth":  { "$value": "{borderWidth.thick}", "$type": "dimension" },
    "text":         { "$value": "{color.text.primary}", "$type": "color" },
    "borderRadius": { "$value": "{radius.md}", "$type": "dimension" },
    "padding":      { "$value": "{spacing.component.md}", "$type": "dimension" },
    "$extensions": {
      "usage": "Use for audience-specific insights, recommendations, or notes within mixed-audience documents."
    }
  },

  "input": {
    "$description": "Form input field component. 5 states. Style selected by Q4.11 (outlined/filled/underlined). DE default: outlined.",

    "default": {
      "background":   { "$value": "{color.white}", "$type": "color" },
      "border":       { "$value": "{color.border.default}", "$type": "color" },
      "borderWidth":  { "$value": "{borderWidth.thin}", "$type": "dimension" },
      "borderRadius": { "$value": "{radius.md}", "$type": "dimension" },
      "text":         { "$value": "{color.text.primary}", "$type": "color" },
      "placeholder":  { "$value": "{color.neutral.400}", "$type": "color" },
      "paddingX":     { "$value": "{space.3}", "$type": "dimension" },
      "paddingY":     { "$value": "{space.2}", "$type": "dimension" },
      "fontSize":     { "$value": "{font.size.base}", "$type": "dimension" },
      "label":        { "$value": "{color.text.primary}", "$type": "color", "$description": "Label text above input." },
      "labelSize":    { "$value": "{font.size.sm}", "$type": "dimension" },
      "labelWeight":  { "$value": "{font.weight.medium}", "$type": "fontWeight" }
    },
    "hover": {
      "border":       { "$value": "{color.border.strong}", "$type": "color" }
    },
    "focus": {
      "border":       { "$value": "{color.brand.primary}", "$type": "color" },
      "outline":      { "$value": "{color.focus.ring}", "$type": "color" },
      "outlineWidth": { "$value": "{borderWidth.medium}", "$type": "dimension" },
      "outlineOffset": { "$value": "2px", "$type": "dimension" }
    },
    "error": {
      "border":       { "$value": "{color.feedback.error.fg}", "$type": "color" },
      "text":         { "$value": "{color.feedback.error.fg}", "$type": "color" },
      "helpText":     { "$value": "{color.feedback.error.fg}", "$type": "color", "$description": "Error message below input." }
    },
    "disabled": {
      "background":   { "$value": "{color.neutral.100}", "$type": "color" },
      "border":       { "$value": "{color.neutral.200}", "$type": "color" },
      "text":         { "$value": "{color.neutral.400}", "$type": "color" },
      "cursor":       { "$value": "not-allowed", "$type": "string" },
      "opacity":      { "$value": "0.6", "$type": "number" }
    },

    "$extensions": {
      "variants": {
        "outlined": "Default. Border all around, white bg.",
        "filled": "Subtle bg fill (neutral-100), lighter border. Modern look.",
        "underlined": "Bottom border only, no bg. Material Design style."
      },
      "related": ["component.checkbox", "component.radio", "component.select"],
      "a11y": "Always associate label with for/id. Required fields use asterisk (*) in error color. Validate on blur, not keystroke."
    }
  },

  "checkbox": {
    "$description": "Checkbox input component.",
    "size":         { "$value": "16px", "$type": "dimension" },
    "borderRadius": { "$value": "{radius.sm}", "$type": "dimension" },
    "off": {
      "border":     { "$value": "{color.border.default}", "$type": "color" },
      "background": { "$value": "{color.white}", "$type": "color" }
    },
    "on": {
      "background": { "$value": "{color.brand.primary}", "$type": "color" },
      "check":      { "$value": "{color.white}", "$type": "color" }
    },
    "focus": {
      "outline":    { "$value": "{color.focus.ring}", "$type": "color" }
    }
  },

  "radio": {
    "$description": "Radio button input component.",
    "size":         { "$value": "16px", "$type": "dimension" },
    "off": {
      "border":     { "$value": "{color.border.default}", "$type": "color" },
      "background": { "$value": "{color.white}", "$type": "color" }
    },
    "on": {
      "border":     { "$value": "{color.brand.primary}", "$type": "color" },
      "dot":        { "$value": "{color.brand.primary}", "$type": "color" },
      "dotSize":    { "$value": "6px", "$type": "dimension" }
    },
    "focus": {
      "outline":    { "$value": "{color.focus.ring}", "$type": "color" }
    }
  },

  "select": {
    "$description": "Select/dropdown input component. Inherits base input styles, adds chevron and dropdown panel.",
    "chevron":      { "$value": "{color.neutral.400}", "$type": "color" },
    "dropdown": {
      "background": { "$value": "{color.white}", "$type": "color" },
      "border":     { "$value": "{color.border.default}", "$type": "color" },
      "shadow":     { "$value": "{shadow.md}", "$type": "shadow" },
      "maxHeight":  { "$value": "240px", "$type": "dimension" },
      "zIndex":     { "$value": "{elevation.zindex.dropdown}", "$type": "number" }
    },
    "option": {
      "hover":      { "$value": "{color.surface.subtle}", "$type": "color" },
      "selected":   { "$value": "{color.brand.primary}", "$type": "color" },
      "selectedBg": { "$value": "{color.primary.50}", "$type": "color" }
    }
  },

  "modal": {
    "$description": "Modal/dialog component. Style selected by Q4.12 (centered/adaptive/slide-in). DE default: centered.",

    "backdrop": {
      "background": { "$value": "{color.black}", "$type": "color" },
      "opacity":    { "$value": "0.5", "$type": "number" },
      "zIndex":     { "$value": "{elevation.zindex.overlay}", "$type": "number" }
    },
    "container": {
      "background":   { "$value": "{color.surface.default}", "$type": "color" },
      "maxWidth":     { "$value": "600px", "$type": "dimension" },
      "borderRadius": { "$value": "{radius.lg}", "$type": "dimension" },
      "shadow":       { "$value": "{shadow.xl}", "$type": "shadow" },
      "padding":      { "$value": "{space.8}", "$type": "dimension" },
      "zIndex":       { "$value": "{elevation.zindex.modal}", "$type": "number" }
    },
    "header": {
      "fontSize":     { "$value": "{font.size.lg}", "$type": "dimension" },
      "fontWeight":   { "$value": "{font.weight.semibold}", "$type": "fontWeight" },
      "marginBottom": { "$value": "{space.4}", "$type": "dimension" }
    },
    "footer": {
      "marginTop":    { "$value": "{space.6}", "$type": "dimension" },
      "gap":          { "$value": "{space.3}", "$type": "dimension", "$description": "Gap between footer action buttons." },
      "alignment":    { "$value": "right", "$type": "string" }
    },
    "animation": {
      "duration":     { "$value": "{duration.moderate.default}", "$type": "duration" },
      "easing":       { "$value": "{easing.out}", "$type": "cubicBezier" }
    },
    "$extensions": {
      "variants": {
        "centered": "Centered card with backdrop. Desktop and mobile.",
        "adaptive": "Centered on desktop, full-screen on mobile (<768px).",
        "slide-in": "Slides from right edge. Drawer/panel style."
      },
      "a11y": "Trap focus inside modal. Escape closes. aria-modal=true. Return focus to trigger on close."
    }
  },

  "toast": {
    "$description": "Toast notification component. Ephemeral feedback messages.",

    "position":     { "$value": "top-right", "$type": "string", "$description": "Screen position. Options: top-right, top-center, bottom-right, bottom-center." },
    "maxVisible":   { "$value": 3, "$type": "number", "$description": "Maximum simultaneous visible toasts." },
    "maxWidth":     { "$value": "400px", "$type": "dimension" },
    "padding":      { "$value": "{space.3} {space.4}", "$type": "string" },
    "borderRadius": { "$value": "{radius.md}", "$type": "dimension" },
    "shadow":       { "$value": "{shadow.lg}", "$type": "shadow" },
    "zIndex":       { "$value": "{elevation.zindex.notification}", "$type": "number" },
    "duration":     { "$value": "5000", "$type": "duration", "$description": "Auto-dismiss time in ms. 10000ms if contains undo action." },
    "animation": {
      "enter":    { "$value": "slide-in", "$type": "string" },
      "exit":     { "$value": "fade-out", "$type": "string" },
      "duration": { "$value": "{duration.moderate.fast}", "$type": "duration" }
    },
    "variants": {
      "success": {
        "background": { "$value": "{color.feedback.success.bg}", "$type": "color" },
        "border":     { "$value": "{color.success.200}", "$type": "color" },
        "icon":       { "$value": "{color.feedback.success.fg}", "$type": "color" }
      },
      "error": {
        "background": { "$value": "{color.feedback.error.bg}", "$type": "color" },
        "border":     { "$value": "{color.error.200}", "$type": "color" },
        "icon":       { "$value": "{color.feedback.error.fg}", "$type": "color" }
      },
      "warning": {
        "background": { "$value": "{color.feedback.warning.bg}", "$type": "color" },
        "border":     { "$value": "{color.accent.200}", "$type": "color" },
        "icon":       { "$value": "{color.feedback.warning.fg}", "$type": "color" }
      },
      "info": {
        "background": { "$value": "{color.feedback.info.bg}", "$type": "color" },
        "border":     { "$value": "{color.info.200}", "$type": "color" },
        "icon":       { "$value": "{color.feedback.info.fg}", "$type": "color" }
      }
    }
  },

  "tooltip": {
    "$description": "Tooltip component for contextual help.",
    "background":   { "$value": "{color.neutral.800}", "$type": "color" },
    "text":         { "$value": "{color.neutral.50}", "$type": "color" },
    "paddingX":     { "$value": "{space.3}", "$type": "dimension" },
    "paddingY":     { "$value": "{space.1}", "$type": "dimension" },
    "borderRadius": { "$value": "{radius.sm}", "$type": "dimension" },
    "maxWidth":     { "$value": "200px", "$type": "dimension" },
    "fontSize":     { "$value": "{font.size.xs}", "$type": "dimension" },
    "delay":        { "$value": "300", "$type": "duration", "$description": "Hover delay before showing (ms)." },
    "shadow":       { "$value": "{shadow.md}", "$type": "shadow" },
    "zIndex":       { "$value": "{elevation.zindex.tooltip}", "$type": "number" },
    "$extensions": {
      "position": "Prefer above target. Auto-flip if clipped. Arrow/caret points to trigger.",
      "a11y": "Use role=tooltip, aria-describedby on trigger. Include keyboard shortcut if available."
    }
  },

  "toggle": {
    "$description": "Toggle/switch component for binary choices.",
    "track": {
      "width":        { "$value": "44px", "$type": "dimension" },
      "height":       { "$value": "24px", "$type": "dimension" },
      "borderRadius": { "$value": "{radius.full}", "$type": "dimension" },
      "off": {
        "background": { "$value": "{color.neutral.300}", "$type": "color" }
      },
      "on": {
        "background": { "$value": "{color.brand.primary}", "$type": "color" }
      }
    },
    "thumb": {
      "size":       { "$value": "20px", "$type": "dimension" },
      "background": { "$value": "{color.white}", "$type": "color" },
      "shadow":     { "$value": "{shadow.sm}", "$type": "shadow" },
      "offset":     { "$value": "2px", "$type": "dimension", "$description": "Inset from track edge." }
    },
    "focus": {
      "outline":    { "$value": "{color.focus.ring}", "$type": "color" }
    },
    "disabled": {
      "opacity":    { "$value": "0.5", "$type": "number" }
    },
    "$extensions": {
      "animation": "Thumb slides from left to right on toggle. Use duration.moderate.fast + easing.default.",
      "a11y": "Use role=switch, aria-checked. Must be keyboard-operable (Space to toggle)."
    }
  },

  "skeleton": {
    "$description": "Loading skeleton/placeholder component. Style selected by Q4.13 (shimmer/pulse/spinner). DE default: shimmer.",
    "background":   { "$value": "{color.neutral.200}", "$type": "color" },
    "borderRadius": { "$value": "{radius.md}", "$type": "dimension" },

    "shimmer": {
      "$description": "Animated gradient sweep effect.",
      "highlight":  { "$value": "{color.neutral.100}", "$type": "color" },
      "duration":   { "$value": "1500", "$type": "duration", "$description": "One shimmer cycle in ms." },
      "direction":  { "$value": "left-to-right", "$type": "string" }
    },
    "pulse": {
      "$description": "Subtle opacity fade effect.",
      "minOpacity": { "$value": "0.4", "$type": "number" },
      "maxOpacity": { "$value": "1.0", "$type": "number" },
      "duration":   { "$value": "2000", "$type": "duration" }
    },
    "shapes": {
      "$description": "Common skeleton placeholder shapes.",
      "text":   { "height": { "$value": "16px", "$type": "dimension" }, "borderRadius": { "$value": "{radius.sm}", "$type": "dimension" } },
      "heading": { "height": { "$value": "24px", "$type": "dimension" }, "borderRadius": { "$value": "{radius.sm}", "$type": "dimension" } },
      "avatar": { "size": { "$value": "40px", "$type": "dimension" }, "borderRadius": { "$value": "{radius.full}", "$type": "dimension" } },
      "image":  { "height": { "$value": "200px", "$type": "dimension" }, "borderRadius": { "$value": "{radius.md}", "$type": "dimension" } }
    },
    "$extensions": {
      "reduced-motion": "When prefers-reduced-motion: reduce, show static skeleton without animation.",
      "a11y": "Use aria-busy=true on container. aria-hidden=true on skeleton elements."
    }
  }
}
