        "borderWidth":  { "$value": "0px", "$type": "dimension" },
        "borderRadius": { "$value": "{radius.md}", "$type": "dimension" },
        "paddingX":     { "$value": "{space.2}", "$type": "dimension" },
        "paddingY":     { "$value": "{space.1}", "$type": "dimension" },
        "shadow":       { "$value": "none", "$type": "shadow" }
      },
      "focus": {
        "background":   { "$value": "transparent", "$type": "color" },
        "text":         { "$value": "{color.brand.primary}", "$type": "color" },
        "border":       { "$value": "{color.brand.primary}", "$type": "color" },
        "borderWidth":  { "$value": "{borderWidth.medium}", "$type": "dimension" },
        "borderRadius": { "$value": "{radius.md}", "$type": "dimension" },
        "paddingX":     { "$value": "{space.2}", "$type": "dimension" },
