    "_partner_subset_logic": "A supporting_documents entry is required for a site_partner ONLY if that partner's contributions[] includes an asset matching the entry's verify-scope. Examples: ATO required only for Grid Contributors (contributions.asset == grid_interconnection); Kadaster required only for Landowners (contributions.asset == land); Equipment OEM specs only for partners contributing that equipment class. For identity docs (KVK), required for every Site Partner regardless of contribution mix."
  },
  "escalation_rules": {
    "non_standard_heat_split": {
      "trigger": "E1 value != '50 : 50 %'",
      "escalate_to": "Carlos Reuven",
      "reason": "Non-standard commercial terms require commercial director approval"
    },
    "co_investment_included": {
      "trigger": "F2 == Include",
      "escalate_to": "Jelmer",
      "reason": "Co-investment affects SPV structure and financing"
    },
    "missing_landowner_consent": {
      "trigger": "grower_is_not_landowner AND landowner_consent not uploaded",
      "escalate_to": "Carlos Reuven + legal-counsel",
      "reason": "Land rights unenforceable without third-party consent (Art. 5.5(g))"
    },
    "joint_signing_authority": {
      "trigger": "A6 == Joint",
      "escalate_to": null,
      "action": "Flag warning: two signatures required on execution page"
    }
  },
  "tagging_notes": "Stage-tag rationale: stage='both' for identity + location fields (captured at LOI Section L/R and carried into HoT); stage='loi' for top-of-funnel intent values (current size, preliminary heat price envelope, heat split); stage='hot' for binding operational parameters that require authoritative documents (ATO MVA numbers, Kadaster instruments, signatory authority, term years, equipment-class provisions). Asset-tag rationale: 'identity' for legal-person fields; 'none' for pure commercial/capital-stack fields not tied to a specific asset class; otherwise the canonical asset taxonomy from deal_yaml_schema.md (land, property, grid_interconnection, gas_connection, equipment_chp, equipment_bess, equipment_solar_pv, heat_supply).",
  "schema_changelog": [
    {
      "version": "1.1",
      "date": "2026-04-20",
      "changes": [
        "Tagged all 58 fields with stage ∈ {loi|hot|both} + asset ∈ enum (see tagging_notes).",
        "Added 8 equipment-class supporting_documents: bess_grid_sharing_agreement, bess_balancing_market_enrollment, chp_commissioning_cert, chp_maintenance_contract, chp_gasketel_cert, solar_pv_yield_report, solar_pv_connection_agreement, co2_supply_contract.",
        "Added validity_days, review_tier, typical_days_to_receive metadata to all supporting_documents entries (existing 7 + new 8).",
        "Added _partner_subset_logic rule describing when a supporting_document is required for a given Site Partner based on their contributions[].",
        "Fixed stale total_fields count: was 48, corrected to 58."
      ]
    }
  ]
}